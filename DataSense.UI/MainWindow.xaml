<Window x:Class="DataSense.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DataSense.UI"
        xmlns:viewmodels="clr-namespace:DataSense.UI.ViewModels"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:converters="clr-namespace:DataSense.UI.Converters"
        mc:Ignorable="d"
        Title="Data Usage &amp; Traffic Analyzer" Height="780" Width="1220" MinWidth="900" MinHeight="600"
        Icon="pack://application:,,,/datasense_icon.png"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal" 
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left Sidebar Navigation (Width controlled by IsSidebarCollapsed) -->
            <ColumnDefinition Width="Auto"/>
            <!-- Main Content Area -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBackground}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="230"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                            <Setter Property="Width" Value="70"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Brand / Title -->
                    <RowDefinition Height="70"/>
                    <!-- Menu Navigation List -->
                    <RowDefinition Height="*"/>
                    <!-- App Health Status Footer -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Brand logo and name -->
                <Grid Grid.Row="0" VerticalAlignment="Center">
                    <!-- Expanded brand row -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0"
                                Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <materialDesign:PackIcon Kind="ChartLineVariant" Width="26" Height="26" Foreground="{StaticResource PrimaryHueMidBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="DataSense" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                    <!-- Collapsed: icon only centered -->
                    <materialDesign:PackIcon Kind="ChartLineVariant" Width="28" Height="28" Foreground="{StaticResource PrimaryHueMidBrush}"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>

                <!-- Sidebar navigation items -->
                <ListBox Grid.Row="1" 
                         SelectedIndex="{Binding SelectedTabIndex}"
                         Background="Transparent" 
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource MaterialDesignListBoxItem}">
                    <ListBox.Resources>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                            <Setter Property="Padding" Value="20,14"/>
                            <Setter Property="Foreground" Value="#718096"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Background" Value="{StaticResource SidebarSelectedBackground}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.Resources>

                    <!-- Dashboard -->
                    <ListBoxItem Padding="0" Height="50">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="ViewDashboardOutline" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Dashboard" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                                       Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        </Grid>
                    </ListBoxItem>

                    <!-- History -->
                    <ListBoxItem Padding="0" Height="50">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="ChartBoxOutline" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="History" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                                       Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        </Grid>
                    </ListBoxItem>

                    <!-- Alerts -->
                    <ListBoxItem Padding="0" Height="50">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="AlertCircleOutline" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Alerts" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                                       Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        </Grid>
                    </ListBoxItem>

                    <!-- Settings -->
                    <ListBoxItem Padding="0" Height="50">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Grid.Column="0" Kind="SettingsOutline" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Settings" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                                       Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        </Grid>
                    </ListBoxItem>

                </ListBox>

                <!-- Sidebar footer status -->
                <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#1A202C" Padding="0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0" Kind="ShieldCheckOutline" Width="22" Height="22" Foreground="#00E5FF"
                                                HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Npcap Active" Foreground="#A0AEC0" FontSize="11" VerticalAlignment="Center"
                                   Visibility="{Binding DataContext.IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- MAIN WORK AREA -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <!-- Top Header Bar -->
                <RowDefinition Height="70"/>
                <!-- Tab Switching Panel -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Header Bar -->
            <Border Grid.Row="0" Background="{StaticResource MainHeaderBackground}" BorderThickness="0,0,0,1" BorderBrush="#1A202C">
                <Grid Margin="12,0,24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sidebar Toggle Button (small and simple DockLeft icon) -->
                    <Button Grid.Column="0"
                            Command="{Binding ToggleSidebarCommand}"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Width="32" Height="32"
                            Foreground="#A0AEC0"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0"
                            ToolTip="Toggle Sidebar">
                        <materialDesign:PackIcon Kind="DockLeft" Width="18" Height="18"/>
                    </Button>

                    <!-- Title based on navigation selection -->
                    <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="17" FontWeight="Bold" Foreground="White">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTabIndex}" Value="0">
                                        <Setter Property="Text" Value="Data Usage &amp; Traffic Analyzer"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
                                        <Setter Property="Text" Value="Historical Reports &amp; Logs"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedTabIndex}" Value="2">
                                        <Setter Property="Text" Value="Data Limit Threshold Settings"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SelectedTabIndex}" Value="3">
                                        <Setter Property="Text" Value="System Preferences &amp; Config"/>
                                    </DataTrigger>

                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- SILENT TAB CONTROL (Content switcher) -->
            <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}" BorderThickness="0" Background="Transparent">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </TabControl.Resources>

                <!-- TAB 0: DASHBOARD (EXACT SCREENSHOT LAYOUT) -->
                <TabItem>
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <!-- Column 0: Daily usage & App breakdown -->
                            <ColumnDefinition Width="1.8*" MinWidth="200"/>
                            <!-- Column 1: Live Bandwidth & Process lists -->
                            <ColumnDefinition Width="3*" MinWidth="300"/>
                            <!-- Column 2: Weekly peak usage & Monthly usage -->
                            <ColumnDefinition Width="2*" MinWidth="220"/>
                        </Grid.ColumnDefinitions>

                        <!-- COLUMN 0 (LEFT) -->
                        <Grid Grid.Column="0" Margin="0,0,16,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 1. Network Speed Meter Card -->
                            <materialDesign:Card Grid.Row="0" Background="{StaticResource MaterialDesignCardBackground}" Padding="16" Margin="0,0,0,12" VerticalAlignment="Stretch">
                                <Grid VerticalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <DockPanel Grid.Row="0" Margin="0,0,0,14">
                                        <TextBlock Text="Network Speed" Foreground="#718096" FontSize="13" FontWeight="SemiBold"/>
                                        <materialDesign:PackIcon Kind="Speedometer" Foreground="#718096" Width="16" Height="16" HorizontalAlignment="Right"/>
                                    </DockPanel>
                                    
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Download Speed -->
                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="ArrowDown" Foreground="#00E5FF" Width="14" Height="14" VerticalAlignment="Center"/>
                                                <TextBlock Text="Download" Foreground="#718096" FontSize="11" FontWeight="SemiBold" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding DownloadSpeedText}" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,6,0,6"/>
                                            <ProgressBar Value="30" IsIndeterminate="False" Height="3" Foreground="#00E5FF" Background="#2D3748" MinHeight="3" MaxHeight="3"/>
                                        </StackPanel>
                                        
                                        <!-- Upload Speed -->
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="ArrowUp" Foreground="#00E676" Width="14" Height="14" VerticalAlignment="Center"/>
                                                <TextBlock Text="Upload" Foreground="#718096" FontSize="11" FontWeight="SemiBold" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding UploadSpeedText}" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,6,0,6"/>
                                            <ProgressBar Value="15" IsIndeterminate="False" Height="3" Foreground="#00E676" Background="#2D3748" MinHeight="3" MaxHeight="3"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </materialDesign:Card>

                            <!-- 2. Daily Usage Card -->
                            <materialDesign:Card Grid.Row="1" Background="{StaticResource MaterialDesignCardBackground}" Padding="16" Margin="0,0,0,12" VerticalAlignment="Stretch">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- Header -->
                                    <DockPanel Grid.Row="0">
                                        <TextBlock Text="Daily Usage" Foreground="#718096" FontSize="13" FontWeight="SemiBold"/>
                                    </DockPanel>
                                    <!-- Value -->
                                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,2">
                                            <TextBlock Text="{Binding DailyUsageText}" Foreground="White" FontSize="26" FontWeight="Bold"/>
                                            <materialDesign:PackIcon Kind="ArrowUp" Foreground="#00E676" Width="18" Height="18" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                        </StackPanel>
                                        <!-- Trend -->
                                        <TextBlock Text="Weekly Trend: +10%" Foreground="#00E676" FontSize="11" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <!-- Sparkline vector wave -->
                                    <Path Grid.Row="2" Stroke="#00E676" StrokeThickness="1.5" Fill="Transparent" Data="M 0,20 C 30,10 60,30 90,15 C 120,5 150,25 180,10 C 200,5 210,18 220,5" VerticalAlignment="Bottom" Height="35" Stretch="Fill"/>
                                </Grid>
                            </materialDesign:Card>

                            <!-- 3. Weekly Usage Card -->
                            <materialDesign:Card Grid.Row="2" Background="{StaticResource MaterialDesignCardBackground}" Padding="16" Margin="0,0,0,12" VerticalAlignment="Stretch">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- Header -->
                                    <DockPanel Grid.Row="0">
                                        <TextBlock Text="Weekly Usage" Foreground="#718096" FontSize="13" FontWeight="SemiBold"/>
                                    </DockPanel>
                                    <!-- Value -->
                                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,2">
                                            <TextBlock Text="{Binding WeeklyUsageText}" Foreground="White" FontSize="26" FontWeight="Bold"/>
                                            <materialDesign:PackIcon Kind="ArrowUp" Foreground="#FFB300" Width="18" Height="18" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                        </StackPanel>
                                        <!-- Trend -->
                                        <TextBlock Text="Avg. Daily: ~350 MB" Foreground="#FFB300" FontSize="11" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <!-- Sparkline vector wave (Gold/Amber) -->
                                    <Path Grid.Row="2" Stroke="#FFB300" StrokeThickness="1.5" Fill="Transparent" Data="M 0,10 C 25,25 50,5 75,18 C 100,10 125,28 150,8 C 175,22 200,5 220,15" VerticalAlignment="Bottom" Height="35" Stretch="Fill"/>
                                </Grid>
                            </materialDesign:Card>

                            <!-- 4. Monthly Usage Card -->
                            <materialDesign:Card Grid.Row="3" Background="{StaticResource MaterialDesignCardBackground}" Padding="16" Margin="0,0,0,0" VerticalAlignment="Stretch">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- Header -->
                                    <DockPanel Grid.Row="0">
                                        <TextBlock Text="Monthly Usage" Foreground="#718096" FontSize="13" FontWeight="SemiBold"/>
                                    </DockPanel>
                                    <!-- Value -->
                                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,2">
                                            <TextBlock Text="{Binding MonthlyUsageText}" Foreground="White" FontSize="26" FontWeight="Bold"/>
                                            <materialDesign:PackIcon Kind="ArrowUp" Foreground="#00B0FF" Width="18" Height="18" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                        </StackPanel>
                                        <!-- Trend -->
                                        <TextBlock Text="Weekly Trend: +10%" Foreground="#00B0FF" FontSize="11" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <!-- Sparkline vector wave -->
                                    <Path Grid.Row="2" Stroke="#00B0FF" StrokeThickness="1.5" Fill="Transparent" Data="M 0,15 C 20,5 55,25 80,10 C 115,0 135,28 170,12 C 190,5 210,18 220,10" VerticalAlignment="Bottom" Height="35" Stretch="Fill"/>
                                </Grid>
                            </materialDesign:Card>
                        </Grid>

                        <!-- COLUMN 1 (CENTER) -->
                        <Grid Grid.Column="1" Margin="0,0,16,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="2*" MinHeight="220"/>
                                <RowDefinition Height="3*" MinHeight="150"/>
                            </Grid.RowDefinitions>

                            <!-- Live Bandwidth Chart Card -->
                            <materialDesign:Card Grid.Row="0" Background="#0D1B2A" Padding="20" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <!-- Header and Legends -->
                                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                                        <TextBlock Text="Live Bandwidth (Mbps)" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <!-- Cyan dot for Download -->
                                            <Ellipse Width="8" Height="8" Fill="#00E5FF" VerticalAlignment="Center"/>
                                            <TextBlock Text="Download" Foreground="#7A9BB5" FontSize="11" Margin="6,0,16,0" VerticalAlignment="Center"/>
                                            <!-- Green dot for Upload -->
                                            <Ellipse Width="8" Height="8" Fill="#00E676" VerticalAlignment="Center"/>
                                            <TextBlock Text="Upload" Foreground="#7A9BB5" FontSize="11" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DockPanel>
                                    <!-- Large Live Chart -->
                                    <lvc:CartesianChart Grid.Row="1"
                                        Series="{Binding SpeedSeries}"
                                        XAxes="{Binding SpeedXAxes}"
                                        YAxes="{Binding SpeedYAxes}"
                                        DrawMarginFrame="{Binding SpeedDrawMarginFrame}"
                                        Background="#0D1B2A"
                                        EasingFunction="{x:Null}"/>
                                </Grid>
                            </materialDesign:Card>

                            <!-- Process Traffic -->
                            <materialDesign:Card Grid.Row="1" Background="{StaticResource MaterialDesignCardBackground}" Padding="18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <DockPanel Grid.Row="0" Margin="0,0,0,12">
                                        <TextBlock Text="Process Traffic Speeds" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                    </DockPanel>
                                    <ListView Grid.Row="1" ItemsSource="{Binding TopProcesses}">
                                        <ListView.View>
                                            <GridView>
                                                <GridView.ColumnHeaderContainerStyle>
                                                    <Style TargetType="GridViewColumnHeader">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Foreground" Value="#718096"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="FontSize" Value="11"/>
                                                    </Style>
                                                </GridView.ColumnHeaderContainerStyle>
                                                <GridViewColumn Header="Process" DisplayMemberBinding="{Binding ProcessName}" Width="160"/>
                                                <GridViewColumn Header="Total Today" DisplayMemberBinding="{Binding TotalText}" Width="110"/>
                                                <GridViewColumn Header="Speed" Width="170">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Grid Width="150">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <ProgressBar Grid.Column="0" Value="{Binding SpeedProgress}" Height="4" Foreground="#00E5FF" Background="#2D3748" VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding SpeedText}" Foreground="#A0AEC0" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </Grid>
                            </materialDesign:Card>
                        </Grid>

                        <!-- COLUMN 2 (RIGHT) -->
                        <Grid Grid.Column="2" Margin="0,0,4,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1.1*"/>
                                <RowDefinition Height="1*"/>
                            </Grid.RowDefinitions>

                            <!-- Custom Period Query Card -->
                            <materialDesign:Card Grid.Row="0" Background="{StaticResource MaterialDesignCardBackground}" Padding="16" Margin="0,0,0,8">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel>
                                        <TextBlock Text="Time Period Usage" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,4"/>
                                        <TextBlock Text="Query network usage for a specific time range today" Foreground="#718096" FontSize="11" Margin="0,0,0,16"/>
 
                                        <!-- START TIME -->
                                        <TextBlock Text="START TIME" Foreground="#718096" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <Border Background="#1A2535" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
 
                                                <!-- Hour -->
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding CustomStartHour, UpdateSourceTrigger=PropertyChanged}"
                                                         Background="Transparent" BorderThickness="0"
                                                         Foreground="White" FontSize="22" FontWeight="Bold"
                                                         Width="36" TextAlignment="Center"
                                                         MaxLength="2"
                                                         materialDesign:HintAssist.Hint="hh"
                                                         Style="{StaticResource MaterialDesignTextBox}"
                                                         CaretBrush="White" VerticalAlignment="Center"/>
 
                                                <!-- Colon -->
                                                <TextBlock Grid.Column="1" Text=":" Foreground="#00E5FF" FontSize="22" FontWeight="Bold"
                                                           VerticalAlignment="Center" Margin="2,0"/>
 
                                                <!-- Minute -->
                                                <TextBox Grid.Column="2"
                                                         Text="{Binding CustomStartMinute, UpdateSourceTrigger=PropertyChanged}"
                                                         Background="Transparent" BorderThickness="0"
                                                         Foreground="White" FontSize="22" FontWeight="Bold"
                                                         Width="36" TextAlignment="Center"
                                                         MaxLength="2"
                                                         materialDesign:HintAssist.Hint="mm"
                                                         Style="{StaticResource MaterialDesignTextBox}"
                                                         CaretBrush="White" VerticalAlignment="Center"/>
 
                                                <!-- AM/PM -->
                                                <ComboBox Grid.Column="4"
                                                          ItemsSource="{Binding AmPmOptions}"
                                                          SelectedItem="{Binding CustomStartAmPm}"
                                                          Foreground="#00E5FF"
                                                          FontWeight="Bold" FontSize="13"
                                                          Width="58"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Right"/>
                                            </Grid>
                                        </Border>
 
                                        <!-- Arrow between times -->
                                        <TextBlock Text="▼  to" Foreground="#4A5568" FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,8"/>
 
                                        <!-- END TIME -->
                                        <TextBlock Text="END TIME" Foreground="#718096" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <Border Background="#1A2535" BorderBrush="#2D3748" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,16">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
 
                                                <!-- Hour -->
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding CustomEndHour, UpdateSourceTrigger=PropertyChanged}"
                                                         Background="Transparent" BorderThickness="0"
                                                         Foreground="White" FontSize="22" FontWeight="Bold"
                                                         Width="36" TextAlignment="Center"
                                                         MaxLength="2"
                                                         materialDesign:HintAssist.Hint="hh"
                                                         Style="{StaticResource MaterialDesignTextBox}"
                                                         CaretBrush="White" VerticalAlignment="Center"/>
 
                                                <!-- Colon -->
                                                <TextBlock Grid.Column="1" Text=":" Foreground="#E91E63" FontSize="22" FontWeight="Bold"
                                                           VerticalAlignment="Center" Margin="2,0"/>
 
                                                <!-- Minute -->
                                                <TextBox Grid.Column="2"
                                                         Text="{Binding CustomEndMinute, UpdateSourceTrigger=PropertyChanged}"
                                                         Background="Transparent" BorderThickness="0"
                                                         Foreground="White" FontSize="22" FontWeight="Bold"
                                                         Width="36" TextAlignment="Center"
                                                         MaxLength="2"
                                                         materialDesign:HintAssist.Hint="mm"
                                                         Style="{StaticResource MaterialDesignTextBox}"
                                                         CaretBrush="White" VerticalAlignment="Center"/>
 
                                                <!-- AM/PM -->
                                                <ComboBox Grid.Column="4"
                                                          ItemsSource="{Binding AmPmOptions}"
                                                          SelectedItem="{Binding CustomEndAmPm}"
                                                          Foreground="#E91E63"
                                                          FontWeight="Bold" FontSize="13"
                                                          Width="58"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Right"/>
                                            </Grid>
                                        </Border>
 
                                        <!-- Query Button -->
                                        <Button Content="Check Usage"
                                                Command="{Binding QueryCustomPeriodUsageCommand}"
                                                Style="{StaticResource MaterialDesignRaisedButton}"
                                                Background="{StaticResource PrimaryHueMidBrush}"
                                                Foreground="{StaticResource PrimaryHueMidForegroundBrush}"
                                                Margin="0,0,0,12"/>
 
                                        <!-- Info / Validation Message -->
                                        <TextBlock Text="{Binding CustomPeriodInfoText}"
                                                   Foreground="#718096"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8"
                                                   Visibility="{Binding CustomPeriodInfoText, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
 
                                        <Border BorderThickness="0,1,0,0" BorderBrush="#2D3748" Padding="0,12,0,0">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
 
                                                <!-- Download -->
                                                <Grid Grid.Row="0" Margin="0,0,0,6">
                                                    <TextBlock Text="Downloaded:" Foreground="#718096" FontSize="12"/>
                                                    <TextBlock Text="{Binding CustomPeriodDownloadedText}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Right" FontSize="12"/>
                                                </Grid>
 
                                                <!-- Upload -->
                                                <Grid Grid.Row="1" Margin="0,0,0,10">
                                                    <TextBlock Text="Uploaded:" Foreground="#718096" FontSize="12"/>
                                                    <TextBlock Text="{Binding CustomPeriodUploadedText}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Right" FontSize="12"/>
                                                </Grid>
 
                                                <!-- Total -->
                                                <Grid Grid.Row="2">
                                                    <TextBlock Text="Total Usage:" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                                                    <TextBlock Text="{Binding CustomPeriodTotalText}" Foreground="#00E5FF" FontWeight="Bold" HorizontalAlignment="Right" FontSize="14"/>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </materialDesign:Card>

                            <!-- Speed Test Card -->
                            <materialDesign:Card Grid.Row="1" Background="{StaticResource MaterialDesignCardBackground}" Padding="16" Margin="0,0,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                        <TextBlock Text="Speed Test" Foreground="#718096" FontSize="13" FontWeight="SemiBold"/>
                                        <materialDesign:PackIcon Kind="Speedometer" Foreground="#718096" Width="16" Height="16" HorizontalAlignment="Right"/>
                                    </DockPanel>

                                    <!-- Gauge circle — scales to fit available space -->
                                    <Viewbox Grid.Row="1" Stretch="Uniform" MaxWidth="200" MaxHeight="200"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Margin="4">
                                        <Grid Width="200" Height="200">
                                            <Ellipse Width="190" Height="190" Stroke="#1A2035" StrokeThickness="14"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Ellipse Width="190" Height="190" Stroke="#00E5FF" StrokeThickness="8" Opacity="0.25"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding SpeedTestCurrentSpeedText}" FontSize="32" FontWeight="Black"
                                                           Foreground="#00E5FF" HorizontalAlignment="Center"/>
                                                <TextBlock Text="MBps" FontSize="12" Foreground="#A0AEC0" HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding SpeedTestPhase}" FontSize="10" Foreground="#718096"
                                                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Ellipse Width="198" Height="198" Stroke="#00E5FF" StrokeThickness="2.5" Opacity="0.4"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                                     Visibility="{Binding IsSpeedTestRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <Ellipse.RenderTransform>
                                                    <RotateTransform CenterX="99" CenterY="99"/>
                                                </Ellipse.RenderTransform>
                                                <Ellipse.Triggers>
                                                    <EventTrigger RoutedEvent="Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Angle"
                                                                                 From="0" To="360" Duration="0:0:1.5"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Ellipse.Triggers>
                                            </Ellipse>
                                        </Grid>
                                    </Viewbox>

                                    <!-- Progress bar -->
                                    <ProgressBar Grid.Row="2" Value="{Binding SpeedTestProgress}" Maximum="100" Height="4"
                                                 Margin="0,4,0,8" Foreground="#00E5FF" Background="#1A2035"/>

                                    <!-- Metrics Grid -->
                                    <Grid Grid.Row="3" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,4,6" HorizontalAlignment="Center">
                                            <TextBlock Text="Download" Foreground="#718096" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding SpeedTestDownloadText}" Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Grid.Row="0" Margin="4,0,0,6" HorizontalAlignment="Center">
                                            <TextBlock Text="Upload" Foreground="#718096" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding SpeedTestUploadText}" Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,4,0" HorizontalAlignment="Center">
                                            <TextBlock Text="Ping" Foreground="#718096" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding SpeedTestPingText}" Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Grid.Row="1" Margin="4,0,0,0" HorizontalAlignment="Center">
                                            <TextBlock Text="Jitter" Foreground="#718096" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding SpeedTestJitterText}" Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Start / Abort Button -->
                                    <Button Grid.Row="4" HorizontalAlignment="Stretch"
                                            Height="36"
                                            Command="{Binding RunSpeedTestCommand}"
                                            Style="{StaticResource MaterialDesignRaisedButton}"
                                            Background="#00E5FF" Foreground="#0A0F1E"
                                            FontWeight="Bold" FontSize="12">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Speedometer" Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Start Test"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSpeedTestRunning}" Value="True">
                                                                <Setter Property="Text" Value="Testing…"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </materialDesign:Card>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- TAB 1: HISTORY VIEW -->
                <TabItem DataContext="{Binding History}">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="3*" MinHeight="200"/>
                            <RowDefinition Height="2*" MinHeight="140"/>
                        </Grid.RowDefinitions>

                        <!-- Controls Panel -->
                        <materialDesign:Card Grid.Row="0" Background="{StaticResource MaterialDesignCardBackground}" Margin="0,0,0,20" Padding="16">
                            <DockPanel>
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                    <TextBlock Text="Year:" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                                    <ComboBox ItemsSource="{Binding YearOptions}" SelectedItem="{Binding SelectedYear}" Foreground="White" Width="85" Margin="0,0,20,0"/>
                                    
                                    <TextBlock Text="Month:" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                                    <ComboBox ItemsSource="{Binding MonthOptions}" SelectedIndex="{Binding SelectedMonthIndex}" Foreground="White" Width="120" Margin="0,0,20,0"/>
                                    
                                    <Button Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding LoadCommand}" Content="Load Logs" Width="100"/>
                                </StackPanel>
                                
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,8,0" Command="{Binding ExportToCsvCommand}" ToolTip="Export Current Log to CSV" Foreground="{StaticResource PrimaryHueMidBrush}" BorderBrush="{StaticResource PrimaryHueMidBrush}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="FileDocument" Margin="0,0,6,0"/>
                                            <TextBlock Text="CSV"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding ExportToPdfCommand}" ToolTip="Export Current Log to PDF" Foreground="{StaticResource PrimaryHueMidBrush}" BorderBrush="{StaticResource PrimaryHueMidBrush}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="FileDocument" Margin="0,0,6,0"/>
                                            <TextBlock Text="PDF"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </DockPanel>
                        </materialDesign:Card>

                        <!-- Historical Daily Chart -->
                        <materialDesign:Card Grid.Row="1" Background="{StaticResource MaterialDesignCardBackground}" Margin="0,0,0,20" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Daily Usage Breakdown (GB)" FontSize="15" FontWeight="Bold" Margin="0,0,0,8" Foreground="White"/>
                                <lvc:CartesianChart Grid.Row="1"
                                                    Series="{Binding DailyChartSeries}"
                                                    XAxes="{Binding XAxes}"
                                                    YAxes="{Binding YAxes}"
                                                    DrawMarginFrame="{Binding HistoryDrawMarginFrame}"
                                                    Background="Transparent"
                                                    MinHeight="160"/>
                            </Grid>
                        </materialDesign:Card>

                        <!-- Grid for Tables -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" MinWidth="260"/>
                                <ColumnDefinition Width="1*" MinWidth="220"/>
                            </Grid.ColumnDefinitions>

                            <!-- Daily details table -->
                            <materialDesign:Card Grid.Column="0" Background="{StaticResource MaterialDesignCardBackground}" Margin="0,0,16,0" Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Daily Breakdown Logs" FontSize="15" FontWeight="Bold" Margin="0,0,0,8" Foreground="White"/>
                                    <ListView Grid.Row="1" ItemsSource="{Binding DailyRows}">
                                        <ListView.View>
                                        <GridView>
                                                <GridViewColumn Header="Date" DisplayMemberBinding="{Binding Date}" Width="Auto"/>
                                                <GridViewColumn Header="Downloaded" DisplayMemberBinding="{Binding Downloaded}" Width="Auto"/>
                                                <GridViewColumn Header="Uploaded" DisplayMemberBinding="{Binding Uploaded}" Width="Auto"/>
                                                <GridViewColumn Header="Total" DisplayMemberBinding="{Binding Total}" Width="Auto"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </Grid>
                            </materialDesign:Card>

                            <!-- Process summary table -->
                            <materialDesign:Card Grid.Column="1" Background="{StaticResource MaterialDesignCardBackground}" Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Monthly Per-App Breakdown" FontSize="15" FontWeight="Bold" Margin="0,0,0,8" Foreground="White"/>
                                    <ListView Grid.Row="1" ItemsSource="{Binding ProcessRows}">
                                        <ListView.View>
                                        <GridView>
                                                <GridViewColumn Header="Application" DisplayMemberBinding="{Binding ProcessName}" Width="Auto"/>
                                                <GridViewColumn Header="↓ DL" DisplayMemberBinding="{Binding DownloadedText}" Width="Auto"/>
                                                <GridViewColumn Header="↑ UL" DisplayMemberBinding="{Binding UploadedText}" Width="Auto"/>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </Grid>
                            </materialDesign:Card>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- TAB 2: DATA LIMITS VIEW -->
                <TabItem>
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Limit Settings Card -->
                        <materialDesign:Card Grid.Row="0" Background="{StaticResource MaterialDesignCardBackground}" Margin="0,0,0,24" Padding="24">
                            <StackPanel>
                                <TextBlock Text="Set Monthly Data Cap" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" Foreground="White"/>
                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*" MinWidth="120"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Monthly Limit (GB):" VerticalAlignment="Center" FontSize="15" Margin="0,0,16,0" Foreground="White"/>
                                    <TextBox Grid.Column="1" Text="{Binding MonthlyLimitGb, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" FontSize="16" Foreground="White" materialDesign:TextFieldAssist.HasClearButton="True"/>
                                    <Button Grid.Column="2" Command="{Binding SaveLimitCommand}" Content="Save Limit" Margin="16,0,0,0" Style="{StaticResource MaterialDesignRaisedButton}"/>
                                </Grid>

                                <Separator Margin="0,0,0,20" Background="#1A202C"/>

                                <TextBlock Text="Current Usage Cap Status" FontSize="16" FontWeight="Bold" Margin="0,0,0,12" Foreground="White"/>
                                <TextBlock Text="{Binding LimitUsageText}" FontSize="15" Margin="0,0,0,8" Foreground="{StaticResource PrimaryHueMidBrush}" FontWeight="SemiBold"/>
                                <ProgressBar Value="{Binding LimitUsagePercentage}" Height="12" Margin="0,0,0,8" Foreground="{StaticResource PrimaryHueMidBrush}" Background="#2D3748"/>
                                <Grid>
                                    <TextBlock Text="0%" HorizontalAlignment="Left" Foreground="Gray"/>
                                    <TextBlock Text="100%" HorizontalAlignment="Right" Foreground="Gray"/>
                                </Grid>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Threshold alert logs card -->
                        <materialDesign:Card Grid.Row="1" Background="{StaticResource MaterialDesignCardBackground}" Padding="24">
                            <StackPanel>
                                <TextBlock Text="Configured Alerts Thresholds" FontSize="16" FontWeight="Bold" Margin="0,0,0,16" Foreground="White"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <materialDesign:PackIcon Kind="Alert" Foreground="Green" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text="50% Threshold Notification Alert active." VerticalAlignment="Center" Margin="10,0,0,0" Foreground="White"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <materialDesign:PackIcon Kind="Alert" Foreground="Orange" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text="75% Warning notification alert active." VerticalAlignment="Center" Margin="10,0,0,0" Foreground="White"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <materialDesign:PackIcon Kind="Alert" Foreground="Red" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text="90% Critical Alert notification active." VerticalAlignment="Center" Margin="10,0,0,0" Foreground="White"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <materialDesign:PackIcon Kind="AlertCircle" Foreground="DarkRed" Width="20" Height="20" VerticalAlignment="Center"/>
                                    <TextBlock Text="100% Data Cap Reached notification and system action ready." VerticalAlignment="Center" Margin="10,0,0,0" Foreground="White"/>
                                </StackPanel>
                                <TextBlock Text="You will receive real-time notifications in your system tray balloon tip when limits are breached." Foreground="Gray" FontSize="11" Margin="0,20,0,0"/>
                            </StackPanel>
                        </materialDesign:Card>
                    </Grid>
                </TabItem>

                <!-- TAB 3: SETTINGS VIEW -->
                <TabItem>
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Preferences settings -->
                        <materialDesign:Card Grid.Row="0" Background="{StaticResource MaterialDesignCardBackground}" Margin="0,0,0,24" Padding="24">
                            <StackPanel>
                                <TextBlock Text="General Preferences" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" Foreground="White"/>

                                <!-- Startup Toggle -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Start DataSense with Windows" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                                        <TextBlock Text="Automatically launches DataSense when your PC starts up to track all metrics." Foreground="Gray"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding IsStartupEnabled}" Command="{Binding ToggleStartupCommand}"/>
                                </Grid>

                                <Separator Margin="0,0,0,16" Background="#1A202C"/>

                                <!-- Dark Theme Toggle -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Enable Dark Theme Layout" FontSize="15" FontWeight="SemiBold" Foreground="White"/>
                                        <TextBlock Text="Switch background layout to a comfortable midnight slate theme." Foreground="Gray"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding IsDarkTheme}" Command="{Binding ToggleThemeCommand}"/>
                                </Grid>

                                <Separator Margin="0,16,0,16" Background="#1A202C"/>

                                <!-- Net Speed Meter Toggle -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Speedometer" Foreground="#4FC3F7" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Net Speed Meter Overlay" FontSize="15" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="Show a real-time transparent upload/download speed meter on your taskbar. Drag to reposition." Foreground="Gray" Margin="26,2,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding IsNetSpeedMeterEnabled}" Command="{Binding ToggleNetSpeedMeterCommand}"/>
                                </Grid>

                                <Separator Margin="0,16,0,16" Background="#1A202C"/>

                                <!-- Pin Net Speed Meter to Taskbar Toggle -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Pin" Foreground="#EF5350" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Pin Speed Meter to Taskbar" FontSize="15" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="Locks the speed meter position directly onto the taskbar (next to the system tray clock)." Foreground="Gray" Margin="26,2,0,0"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="1" Style="{StaticResource MaterialDesignSwitchToggleButton}" IsChecked="{Binding IsNetSpeedMeterPinned}" Command="{Binding ToggleNetSpeedMeterPinnedCommand}"/>
                                </Grid>

                                <Separator Margin="0,16,0,16" Background="#1A202C"/>

                                <!-- Customization Options (Color & Size) -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Palette" Foreground="#81C784" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Speed Meter Customization" FontSize="15" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="Configure the font color and text size of the speed overlay." Foreground="Gray" Margin="26,2,0,0"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- Color Selection -->
                                        <ComboBox Width="110" Margin="0,0,12,0" 
                                                  ItemsSource="{Binding NetSpeedMeterAvailableColors}"
                                                  SelectedItem="{Binding SelectedNetSpeedMeterColor}"
                                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                  materialDesign:HintAssist.Hint="Color"
                                                  Foreground="White"
                                                  BorderBrush="#33FFFFFF"/>
                                        
                                        <!-- Font Size Selection -->
                                        <ComboBox Width="80" 
                                                  ItemsSource="{Binding NetSpeedMeterAvailableFontSizes}"
                                                  SelectedItem="{Binding SelectedNetSpeedMeterFontSize}"
                                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                  materialDesign:HintAssist.Hint="Size"
                                                  Foreground="White"
                                                  BorderBrush="#33FFFFFF"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Adapter Selection Card -->
                        <materialDesign:Card Grid.Row="1" Background="{StaticResource MaterialDesignCardBackground}" Padding="24">
                            <StackPanel>
                                <TextBlock Text="Select Network Adapter to Monitor" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" Foreground="White"/>
                                <TextBlock Text="Choose which physical Ethernet or Wi-Fi adapter's raw packets will be captured by the Npcap engine:" Margin="0,0,0,16" Foreground="Gray"/>

                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" ItemsSource="{Binding AvailableAdapters}" SelectedItem="{Binding SelectedAdapter}" FontSize="14" DisplayMemberPath="Name" Foreground="White" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Command="{Binding ChangeAdapterCommand}" Content="Apply Adapter" Margin="16,0,0,0" Style="{StaticResource MaterialDesignRaisedButton}"/>
                                </Grid>
                            </StackPanel>
                        </materialDesign:Card>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>
    </Grid>
</Window>
