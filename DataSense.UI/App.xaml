<Application x:Class="DataSense.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DataSense.UI"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Startup="OnStartup"
             Exit="OnExit">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- MaterialDesignThemes v5: BundledTheme drives dark/light + colors -->
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="Cyan" SecondaryColor="Blue" />
                <!-- v5 uses MaterialDesign2.Defaults (classic Material Design style) -->
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- CUSTOM PREMIUM BRAND OVERRIDES -->
            <SolidColorBrush x:Key="MaterialDesignPaper" Color="#0B0E14"/>
            <SolidColorBrush x:Key="MaterialDesignCardBackground" Color="#131924"/>
            <SolidColorBrush x:Key="MaterialDesignBody" Color="#E2E8F0"/>
            <SolidColorBrush x:Key="MaterialDesignBodyLight" Color="#718096"/>
            
            <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="#00E5FF"/>
            <SolidColorBrush x:Key="PrimaryHueMidForegroundBrush" Color="#0B0E14"/>

            <SolidColorBrush x:Key="SidebarBackground" Color="#0F131D"/>
            <SolidColorBrush x:Key="SidebarSelectedBackground" Color="#171E2D"/>
            <SolidColorBrush x:Key="MainHeaderBackground" Color="#0F131D"/>
            <SolidColorBrush x:Key="CardInternalBackground" Color="#171E2D"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
