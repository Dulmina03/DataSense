<Window x:Class="DataSense.UI.NetSpeedMeterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:DataSense.UI.Converters"
        Title="NetSpeedMeter"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="90"
        Height="36"
        WindowStartupLocation="Manual"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <conv:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
    </Window.Resources>

    <Grid Background="Transparent">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Download Speed -->
            <StackPanel Orientation="Horizontal" Margin="0,1">
                <TextBlock Text="▼" Foreground="#4FC3F7" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="Bold"/>
                <TextBlock x:Name="DownloadText"
                           Text="0 B/s"
                           FontSize="11"
                           FontFamily="Segoe UI"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           MinWidth="70"
                           Foreground="{Binding IsDarkTheme, Converter={StaticResource BoolToBrushConverter}}"/>
            </StackPanel>

            <!-- Upload Speed -->
            <StackPanel Orientation="Horizontal" Margin="0,1">
                <TextBlock Text="▲" Foreground="#EF5350" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="Bold"/>
                <TextBlock x:Name="UploadText"
                           Text="0 B/s"
                           FontSize="11"
                           FontFamily="Segoe UI"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           MinWidth="70"
                           Foreground="{Binding IsDarkTheme, Converter={StaticResource BoolToBrushConverter}}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
